knitr::opts_chunk$set(echo = TRUE,warning=FALSE,message = FALSE)
library(tidyverse)
set.seed(44)
data.frame(x=rnorm(30),y=rnorm(30)) |>
ggplot(aes(x=x,y=y))+
geom_point()+
geom_smooth(method = "lm")
This type of experiment is called a *Monte Carlo Simulation* and the output approximates what we call the *null^[This term comes from hypothesis testing where the null hypothesis is that the true slope between $x$ and $Y$ in our model is $\beta_1=0$.]* sampling distribution of the estimator $\hat \beta_1$. Notice that the mean is close to 0:
max(abs(slopes))
set.seed(45)
slopes = replicate(1000, {
x = rnorm(30)
y = rnorm(30)
coef(lm(y ~ x))[2]
})
hist(slopes)
max(abs(slopes))
cat("lower = ",mean(slopes) -2*sd(slopes), ",upper = "mean(slopes) +2*sd(slopes))
cat("lower = ",mean(slopes) -2*sd(slopes), ",upper = ", mean(slopes) +2*sd(slopes))
x = rnorm(30)
y = x+rnorm(30)
model = lm(y ~ x)
coef(model)[2]
