hist_data <- hist(slopes, plot = FALSE)
plot(hist_data, col = ifelse(abs(hist_data$mids) > 0.5, "steelblue", "lightgray"),
main = "Null Sampling Distribution of Slope",
xlab = "Slope",
border = "white")
text(0.75, max(hist_data$counts) * 0.8, "Area = 0.008", col = "steelblue", cex = 0.9)
